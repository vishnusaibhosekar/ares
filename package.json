{
    "name": "ares",
    "version": "1.0.0",
    "description": "Actor Resolution & Entity Service - Identifies operators behind counterfeit storefronts",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest",
        "test:unit": "jest tests/unit",
        "test:integration": "jest tests/integration",
        "test:watch": "jest --watch",
        "db:migrate": "tsx db/run-migrations.ts",
        "db:seed": "tsx db/seed.ts",
        "demo": "tsx demos/end-to-end.ts",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "entity-resolution",
        "fraud-detection",
        "counterfeit",
        "clustering",
        "embeddings"
    ],
    "author": "Insforge x Qoder Hackathon",
    "license": "MIT",
    "dependencies": {
        "@insforge/sdk": "^1.2.2",
        "axios": "^1.6.0",
        "cors": "^2.8.6",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "pg": "^8.11.3",
        "pino": "^8.16.0",
        "pino-pretty": "^10.2.3",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.8",
        "@types/node": "^20.9.0",
        "@types/pg": "^8.10.9",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^9.0.6",
        "@typescript-eslint/eslint-plugin": "^6.10.0",
        "@typescript-eslint/parser": "^6.10.0",
        "eslint": "^8.53.0",
        "jest": "^29.7.0",
        "prettier": "^3.1.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "tsx": "^4.1.1",
        "typescript": "^5.2.2"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
