# ARES Environment Configuration
# Copy this file to .env and fill in the values

# Insforge Configuration
# Get these from `npx @insforge/cli current` and `npx @insforge/cli secrets list`
INSFORGE_BASE_URL=https://your-app.us-west.insforge.app
INSFORGE_ANON_KEY=your_anon_key_here

# MIXEDBREAD API key for embeddings (optional)
MIXEDBREAD_API_KEY=your_api_key_here

# Application environment
NODE_ENV=development

# Server port
PORT=3000

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
